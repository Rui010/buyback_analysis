# ========================================
# SQLiteデータベース設定
# ========================================
SQLITE_DB_URL=sqlite:///buyback.db

# ========================================
# PostgreSQL設定（TDnetデータ読み込み用）
# ========================================
POSTGRESQL_DB_HOST=your_host_here
POSTGRESQL_DB_PORT=5432
POSTGRESQL_DB_NAME=your_db_name
POSTGRESQL_DB_USER=your_username
POSTGRESQL_DB_PASSWORD=your_password

# ========================================
# Google Gemini API設定
# ========================================
GEMINI_API_KEY=your_gemini_api_key_here

# ========================================
# PDF保存先
# ========================================
PDF_DOWNLOAD_PATH=./data/

# ========================================
# データ取得期間設定
# 
# DAYS_BACK: デフォルトで遡る日数（デフォルト: 5）
#   例: 5 → 過去5日間のデータを取得
# 
# SYSTEM_START_DATE: データ取得開始日（YYYY-MM-DD形式）
#   例: 2025-04-01
#   指定時はDays_BACKを無視します
# 
# SYSTEM_END_DATE: データ取得終了日（YYYY-MM-DD形式）
#   例: 2025-04-30
#   指定時はDays_BACKを無視します
#
# 注意: SYSTEM_START_DATEとSYSTEM_END_DATEは両方指定してください
# ========================================
DAYS_BACK=5
# SYSTEM_START_DATE=2025-04-01
# SYSTEM_END_DATE=2025-04-30

# ========================================
# ネイティブPDF処理設定（省略可）
# true にするとpypdfテキスト抽出の代わりにGemini Files APIでPDFを直接処理する
# 中期経営計画のような表・グラフが多いPDFで精度向上が期待できる
# ========================================
# BUYBACK_USE_NATIVE_PDF=false
# MIDTERM_USE_NATIVE_PDF=false

# ========================================
# Slack通知設定（省略可）
# 設定しない場合は通知を送らずスキップされる
# ========================================
# SLACK_TOKEN=xoxb-your-bot-token
# SLACK_CHANNEL=#your-channel
# SLACK_MENTION=@your-user-id

LOG_DIR=logs          # ログ保存先（省略可、デフォルト: logs）
LOG_BACKUP_COUNT=30   # 保持日数（省略可、デフォルト: 30）
